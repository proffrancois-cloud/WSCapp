{
  "name": "wsc-alpaca-quiz",
  "version": "1.0.0",
  "private": true,
  "description": "World Scholar's Cup 2026 Study Routes as a web app and desktop app.",
  "main": "desktop/electron/main.js",
  "engines": {
    "node": "24.x",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.12.1",
  "scripts": {
    "serve": "python3 -m http.server 4173",
    "dev:3d": "vite --host 127.0.0.1",
    "build:3d": "vite build",
    "build:pages": "VITE_BASE=/WSCapp/ vite build && node ../tools/deployment/prepare-github-pages.mjs --target=pages",
    "build:vercel": "VITE_BASE=/ vite build && node ../tools/deployment/prepare-github-pages.mjs --target=vercel",
    "audit:pages": "node ../tools/validators/audit-public-artifact.mjs dist-pages && node ../tools/validators/css-import-graph-test.mjs --artifact dist-pages",
    "audit:vercel": "node ../tools/validators/audit-public-artifact.mjs dist-vercel && node ../tools/validators/css-import-graph-test.mjs --artifact dist-vercel",
    "verify": "npm run test:node-version && npm run test:app-js-budget && npm run test:composition-root-budget && npm run typecheck:3d && npm run test:theme && npm run test:classic-scripts && npm run test:smoke && npm run test:auth-privacy && npm run test:storage-failure && npm run test:headers && npm run test:html-boundary && npm run test:html-sinks && npm run test:css-imports && npm run test:campus-network && npm run test:campus-assets && npm run build:pages && npm run audit:pages && npm run test:a11y-smoke && npm run test:campus-smoke && npm run test:campus-performance",
    "preview:3d": "vite preview --host 127.0.0.1",
    "typecheck:3d": "tsc --noEmit -p tsconfig.json",
    "theme:extract": "node ../tools/generators/extract-current-2026-theme.mjs",
    "theme:build-question-bank": "node ../tools/generators/build-question-bank-from-theme.mjs ../content/themes/2026",
    "theme:validate": "node ../tools/validators/validate-theme.mjs ../content/themes/2026",
    "theme:build-runtime": "node ../tools/generators/build-current-runtime-from-theme.mjs ../content/themes/2026 generated/current-runtime",
    "theme:compare": "node ../tools/validators/compare-runtime-compat.mjs . generated/current-runtime --profile active-runtime",
    "theme:compare:strict": "node ../tools/validators/compare-runtime-compat.mjs . generated/current-runtime --profile strict",
    "theme:compare:legacy-audit": "node ../tools/validators/compare-runtime-compat.mjs . generated/current-runtime --profile legacy-audit",
    "theme:check-runtime": "node ../tools/validators/check-current-runtime-generated.mjs",
    "theme:refresh": "npm run theme:extract && npm run theme:build-question-bank && npm run theme:validate && npm run theme:build-runtime && npm run theme:compare",
    "test:node-version": "node ../tools/validators/validate-node-version.mjs",
    "test:app-js-budget": "node ../tools/validators/check-app-js-budget.mjs",
    "test:composition-root-budget": "node ../tools/validators/check-composition-root-budget.mjs",
    "test:theme": "npm run theme:validate && npm run theme:compare && npm run theme:check-runtime",
    "verify:vercel": "npm run build:vercel && npm run audit:vercel",
    "test:classic-scripts": "node ../tools/validators/classic-script-dependency-map-test.mjs",
    "test:smoke": "node ../tools/validators/smoke-test-app.mjs",
    "test:auth-privacy": "node ../tools/validators/auth-privacy-test.mjs",
    "test:storage-failure": "node ../tools/validators/storage-failure-test.mjs",
    "test:headers": "node ../tools/validators/validate-vercel-headers.mjs",
    "test:html-boundary": "node ../tools/validators/html-boundary-test.mjs",
    "test:html-sinks": "node ../tools/validators/html-sink-guard.mjs",
    "test:css-imports": "node ../tools/validators/css-import-graph-test.mjs",
    "test:campus-network": "node ../tools/validators/campus-network-guardrails-test.mjs",
    "test:campus-assets": "node ../tools/validators/campus-asset-manifest-test.mjs",
    "optimize:campus-glbs": "node ../tools/assets/optimize-campus-glbs.mjs",
    "test:a11y-smoke": "playwright test e2e/modal-mobile.spec.ts",
    "test:campus-smoke": "playwright test e2e/campus-preview.spec.ts",
    "test:campus-performance": "playwright test e2e/campus-performance.spec.ts",
    "desktop:dev": "electron .",
    "desktop:pack": "electron-builder --dir",
    "desktop:mac": "electron-builder --mac dmg zip",
    "desktop:win": "electron-builder --win nsis portable"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "build": {
    "appId": "org.worldscholarscup.study.routes",
    "productName": "WSC 2026 Study Routes",
    "directories": {
      "buildResources": "desktop/icons",
      "output": "../builds/current"
    },
    "files": [
      "index.html",
      "styles.css",
      "styles-*.css",
      "app.js",
      "data.js",
      "knowledge-bank.js",
      "alpaca-channel.js",
      "raw-content-bank.js",
      "assets-config.js",
      "supabase-config.js",
      "manifest.webmanifest",
      "service-worker.js",
      "pwa.js",
      "alpaca-campus-3d/**/*",
      "src/**/*",
      "generated/**/*",
      "assets/**/*",
      "content/**/*",
      "app-icons/**/*",
      "desktop/electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "desktop/icons/app.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "desktop/icons/app.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  }
}
